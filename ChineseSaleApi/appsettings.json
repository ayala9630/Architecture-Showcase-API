{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Password": "YourSecureRedisPassword123!"
  },
  "CacheSettings": {
    "Categories": {
      "GetAllTtlHours": 24,
      "GetByIdTtlHours": 24
    },
    "Lotteries": {
      "GetAllTtlHours": 12,
      "GetByIdTtlHours": 12
    },
    "Packages": {
      "GetAllByLotteryTtlHours": 6,
      "GetByIdTtlHours": 6
    },
    "Gifts": {
      "GetAllByLotteryTtlHours": 5,
      "GetByIdTtlHours": 5,
      "GetCountByLotteryTtlHours": 5
    }
  },
  "RateLimiting": {
    "WindowSeconds": 60,
    "PermitLimit": 100,
    "SegmentsPerWindow": 6
  }
}